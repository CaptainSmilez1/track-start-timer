{
  "name": "starta",
  "version": "1.0.0",
  "description": "A randomized \"on your marks, set, go\" starter timer for track practice — runs entirely in the browser, installable as an app on phones (PWA).",
  "main": "sw.js",
  "scripts": {
    "sounds": "node scripts/render-sounds.js",
    "icons": "node scripts/make-icons.js",
    "build:www": "node scripts/build-capacitor-www.js",
    "cap:sync": "npm run build:www && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaptainSmilez1/track-start-timer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/CaptainSmilez1/track-start-timer/issues"
  },
  "homepage": "https://github.com/CaptainSmilez1/track-start-timer#readme",
  "dependencies": {
    "@capacitor-community/native-audio": "^8.0.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2"
  }
}
